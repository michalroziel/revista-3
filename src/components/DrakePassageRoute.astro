---
interface Props {
  caption?: string;
  class?: string;
}

const {
  caption = 'A hand-drawn route from Ushuaia across the Drake Passage to the Antarctic Peninsula.',
  class: className = '',
} = Astro.props;
---

<figure class={`drake-route not-prose ${className}`.trim()} data-drake-route>
  <div class="drake-route__frame">
    <div class="drake-route__meta">
      <p class="drake-route__eyebrow">Drake Passage</p>
      <p class="drake-route__subhead">Ushuaia to the Antarctic Peninsula</p>
    </div>

    <svg
      class="drake-route__svg"
      viewBox="0 0 960 300"
      role="img"
      aria-label="Stylized route from Ushuaia across the Drake Passage to the Antarctic Peninsula."
    >
      <g class="drake-route__grid" aria-hidden="true">
        <path d="M86 86C233 69 388 71 546 89C666 102 779 118 890 114" />
        <path d="M78 138C236 124 401 127 560 146C692 161 794 176 884 171" />
        <path d="M91 205C247 192 403 196 546 215C658 229 762 235 863 228" />
      </g>

      <g class="drake-route__land" aria-hidden="true">
        <path d="M149 47C127 59 116 84 121 107C126 128 141 136 158 145C177 155 184 173 181 193C179 212 187 227 205 241C185 237 166 224 150 205C135 187 128 167 130 149C132 129 123 112 108 98C94 85 90 61 103 44C116 28 134 26 149 47Z" />
        <path d="M734 207C747 187 773 176 802 178C832 179 860 170 889 148C881 173 865 188 848 196C829 205 813 218 806 240C789 236 772 226 757 216C749 211 742 208 734 207Z" />
        <path d="M700 222C711 209 728 201 747 202C734 214 724 229 717 247C708 242 703 234 700 222Z" />
      </g>

      <path
        class="drake-route__path drake-route__path--base"
        d="M166 150C245 122 320 108 404 117C487 126 565 153 648 176C702 191 748 198 794 194"
        aria-hidden="true"
      />
      <path
        class="drake-route__path drake-route__path--animated"
        d="M166 150C245 122 320 108 404 117C487 126 565 153 648 176C702 191 748 198 794 194"
        data-route-path
      />

      <circle class="drake-route__anchor" cx="166" cy="150" r="4" aria-hidden="true" />
      <circle class="drake-route__anchor" cx="794" cy="194" r="4" aria-hidden="true" />
      <circle class="drake-route__marker" data-route-marker cx="166" cy="150" r="5" aria-hidden="true" />

      <text class="drake-route__label" x="132" y="133">USHUAIA</text>
      <text class="drake-route__label drake-route__label--mid" x="396" y="96">DRAKE PASSAGE</text>
      <text class="drake-route__label drake-route__label--destination" x="692" y="165">
        ANTARCTIC PENINSULA
      </text>
      <text class="drake-route__note" x="238" y="199">Roaring forties. Furious fifties. Southern Ocean.</text>
    </svg>
  </div>

  <figcaption class="drake-route__caption">
    {caption}
  </figcaption>
</figure>

<script is:inline>
  (() => {
    const setupDrakeRoutes = () => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      document.querySelectorAll('[data-drake-route]').forEach((root) => {
        if (root.dataset.drakeReady === 'true') {
          return;
        }

        const path = root.querySelector('[data-route-path]');
        const marker = root.querySelector('[data-route-marker]');

        if (!path || !marker) {
          return;
        }

        root.dataset.drakeReady = 'true';

        const totalLength = path.getTotalLength();

        root.style.setProperty('--route-length', `${totalLength}`);
        root.classList.add('is-enhanced');

        const placeMarker = (progress) => {
          const point = path.getPointAtLength(totalLength * progress);
          marker.setAttribute('cx', point.x.toFixed(2));
          marker.setAttribute('cy', point.y.toFixed(2));
        };

        if (reduceMotion) {
          path.style.strokeDasharray = `${totalLength}`;
          path.style.strokeDashoffset = '0';
          placeMarker(1);
          root.classList.add('is-visible', 'is-complete');
          return;
        }

        path.style.strokeDasharray = `${totalLength}`;
        path.style.strokeDashoffset = `${totalLength}`;
        placeMarker(0);

        const startAnimation = () => {
          if (root.dataset.drakeStarted === 'true') {
            return;
          }

          root.dataset.drakeStarted = 'true';
          root.classList.add('is-visible');

          const duration = 2800;
          const startedAt = performance.now();

          const tick = (now) => {
            const progress = Math.min((now - startedAt) / duration, 1);
            path.style.strokeDashoffset = `${totalLength * (1 - progress)}`;
            placeMarker(progress);

            if (progress < 1) {
              requestAnimationFrame(tick);
              return;
            }

            root.classList.add('is-complete');
          };

          requestAnimationFrame(tick);
        };

        if (!('IntersectionObserver' in window)) {
          startAnimation();
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                return;
              }

              startAnimation();
              observer.disconnect();
            });
          },
          { threshold: 0.4 }
        );

        observer.observe(root);
      });
    };

    if (!window.__drakeRouteSetupBound) {
      window.__drakeRouteSetupBound = true;
      window.__drakeRouteSetup = setupDrakeRoutes;
      document.addEventListener('astro:page-load', window.__drakeRouteSetup);
    }

    window.__drakeRouteSetup();
  })();
</script>

<style>
  .drake-route {
    margin: 2.5rem 0 3rem;
    color: inherit;
  }

  .drake-route__frame {
    position: relative;
    padding: 1rem 0 0.5rem;
  }

  .drake-route__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .drake-route__eyebrow,
  .drake-route__subhead,
  .drake-route__caption {
    margin: 0;
    font-family: var(--font-overpass-mono), 'Overpass Mono', monospace;
  }

  .drake-route__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    opacity: 0.62;
  }

  .drake-route__subhead {
    font-size: 0.86rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.48;
    text-align: right;
  }

  .drake-route__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .drake-route__grid path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1;
    stroke-dasharray: 6 12;
    opacity: 0.12;
  }

  .drake-route__land path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    opacity: 0.28;
  }

  .drake-route__path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .drake-route__path--base {
    stroke-width: 2.25;
    opacity: 0.16;
  }

  .drake-route__path--animated {
    stroke-width: 3.25;
    opacity: 0.88;
  }

  .drake-route__anchor {
    fill: currentColor;
    opacity: 0.45;
  }

  .drake-route__marker {
    fill: currentColor;
    opacity: 0;
    transition: opacity 180ms ease-out;
  }

  .drake-route.is-visible .drake-route__marker {
    opacity: 0.95;
  }

  .drake-route__label,
  .drake-route__note {
    fill: currentColor;
    font-family: var(--font-overpass-mono), 'Overpass Mono', monospace;
  }

  .drake-route__label {
    font-size: 13px;
    letter-spacing: 0.16em;
    opacity: 0.58;
  }

  .drake-route__label--mid {
    opacity: 0.72;
  }

  .drake-route__label--destination {
    text-anchor: start;
  }

  .drake-route__note {
    font-size: 12px;
    letter-spacing: 0.08em;
    opacity: 0.36;
  }

  .drake-route__caption {
    margin-top: 0.5rem;
    font-size: 0.94rem;
    line-height: 1.5;
    opacity: 0.7;
  }

  @media (max-width: 720px) {
    .drake-route {
      margin: 2rem 0 2.5rem;
    }

    .drake-route__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }

    .drake-route__subhead {
      text-align: left;
    }

    .drake-route__label {
      font-size: 11px;
      letter-spacing: 0.12em;
    }

    .drake-route__note {
      font-size: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .drake-route__marker {
      transition: none;
    }
  }
</style>
